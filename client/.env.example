# Development (recommended): omit VITE_API_URL — browser calls /api/* and Vite
# proxies to http://127.0.0.1:8000. You MUST run the API (server/) or you get
# "Cannot POST /api/...".
#
# If the API is NOT on port 8000 (check server console: "Server listening on port …"):
# VITE_PROXY_API=http://127.0.0.1:8001
# or bypass the proxy (backend must allow CORS for http://localhost:5173):
# VITE_API_URL=http://127.0.0.1:8001/api
#
# Production build (required when frontend and API are on different hosts):
# VITE_API_URL=https://your-backend.com/api
