MONGO_URI=mongodb://127.0.0.1:27017/kaam
JWT_SECRET=replace-with-long-random-string-min-32-chars
PORT=8000

# Browser origin(s) allowed for CORS (comma-separated for multiple)
CLIENT_URL=http://localhost:5173

# Development only — never enable in production
OTP_DEBUG=false
DEMO_MODE=false

# --- Outbound email (uncomment ONE method) ---

# Option A — Gmail App Password: https://myaccount.google.com/apppasswords
# GMAIL_USER=youremail@gmail.com
# GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Option B — Resend: https://resend.com
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=KAAM <onboarding@resend.dev>

# Option C — Generic SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=youremail@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=KAAM <youremail@gmail.com>
